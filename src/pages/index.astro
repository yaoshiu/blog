---
import RepoCard from '@components/RepoCard.astro';
import Tag from '@components/Tag.astro';
import Base from '@layouts/Base.astro';
import SlideIn from '@components/SlideIn.astro';
import { getCollection } from 'astro:content';
import postData from '@helpers/postData';

const TITLE = 'Fay Ash';
const DESCRIPTION = "Fay Ash's personal website and blog.";
const STEAMID = 'fayash';

const REPOS =[
  {
    repo: 'yaoshiu/opus',
    desc: 'A minimal, statically-scoped Lisp dialect based on f-expressions, compiled to WebAssembly.',
    icon: 'i-fa6-solid:code',
  },
  {
    repo: 'yaoshiu/algebraic-ds',
    desc: 'Zero-cost abstract algebra data structures in Rust using compile-time branded types.',
    icon: 'i-fa6-solid:cubes',
  },
];

const SKILLS =[
  {
    title: 'Systems & Infrastructure',
    tags:[
      { icon: 'i-devicon:nixos', name: 'Nix', href: 'https://nixos.org/' },
      { icon: 'i-devicon:cplusplus', name: 'C++', href: 'https://isocpp.org/' },
      { icon: 'i-devicon:linux', name: 'Linux OS', href: 'https://kernel.org/' },
      { icon: 'i-devicon:docker', name: 'Containers', href: 'https://www.docker.com/' },
    ],
  },
  {
    title: 'Languages & Theory',
    tags:[
      { icon: 'i-devicon:rust', name: 'Rust', href: 'https://www.rust-lang.org/' },
      { icon: 'i-devicon:haskell', name: 'Haskell', href: 'https://www.haskell.org/' },
      { icon: 'i-devicon:python', name: 'Python', href: 'https://www.python.org/' },
      { icon: 'i-devicon:typescript', name: 'TypeScript', href: 'https://www.typescriptlang.org/' },
    ],
  },
  {
    title: 'Focus Areas',
    tags:[
      { icon: 'i-fa6-solid:microchip', name: 'Compilers & PLT', href: '#' },
      { icon: 'i-fa6-solid:hammer', name: 'Build Systems', href: '#' },
      { icon: 'i-fa6-solid:globe', name: 'WebAssembly', href: '#' },
    ],
  }
];

const posts = await getCollection('posts');
const postsData = await Promise.all(
  posts.map((entry) => postData({ entry, site: Astro.site })),
);

const data = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  blogPost: postsData,
  headline: TITLE,
  image: new URL('/og.png', Astro.site),
  license: 'https://creativecommons.org/licenses/by-nc-sa/4.0/',
  description: DESCRIPTION,
  author: {
    '@type': 'Person',
    name: 'Fay Ash',
    url: Astro.site,
  },
};
---

<Base title={TITLE} description={DESCRIPTION} image="/og.png" {data}>
  <article class="prose">
    <SlideIn>
      <h1>Fay Ash</h1>

      <p>
        Hi, Fay Ash here. I am a <strong>Systems and Platform Engineer</strong> based in Shanghai, China. 
        My work revolves around untangling legacy infrastructures, optimizing cross-compilation toolchains, and exploring the elegant boundaries of <strong>Programming Language Theory (PLT)</strong>.
      </p>

      <p>
        I am a builder driven by first principles. Whether it's reverse-engineering messy C++ build systems to achieve hermetic environments, or implementing continuation-passing style (CPS) interpreters in Haskell, I enjoy diving to the absolute bottom of the tech stack.
      </p>

      <p>Selected works:</p>
      <ul class="not-prose">
        {
          REPOS.map(({ repo, desc  }) => (
            <li class="my-8">
              <RepoCard repo={repo} desc={desc} />
            </li>
          ))
        }
      </ul>

      <p>My technical stack and current focus:</p>
      <ul>
        {
          SKILLS.map(({ title, tags }) => (
            <li>
              <strong>{title}:</strong>
              {tags && (
                <ul class="not-prose" inline>
                  {tags.map(({ icon, name, href }) => (
                    <li class="inline">
                      <Tag {href} target="_blank" rel="noopener noreferrer">
                        <span class={`${icon} inline-block`}></span>
                        {name}
                      </Tag>
                    </li>
                  ))}
                </ul>
              )}
            </li>
          ))
        }
      </ul>

      <p>
        Outside of the terminal, I often describe myself as a "creature driven by curiosity." When a problem captures my imagination—be it zero-cost abstractions or abstract algebra—I can immerse myself in it for days.
      </p>

      <p>
        I'm also an avid consumer of progressive rock, experimental music from the 60s to the 80s, and classic cinema (slowly working my way through the <i>Sight & Sound</i> list). But above all, I am a seasoned gamer. My longest-running obsession is the <i>Monster Hunter</i> series, my all-time favorite is <i>Red Dead Redemption 2</i>, and I've been a loyal fan of the <i>GTA</i> franchise since Vice City.
      </p>

      <p>
        If you share an interest in systems programming, obscure Lisp dialects, or just want to hunt some monsters together, feel free to connect with me or add me on
        <span class="not-prose">
          <Tag
            href=`https://steamcommunity.com/id/${STEAMID}`
            target="_blank"
            rel="noopener noreferrer"
          >
            <span class="i-fa6-brands:steam inline-block"></span>
            Steam
          </Tag>
        </span>.
      </p>

      <p>
        Thanks for stopping by, and enjoy your time here!
      </p>
    </SlideIn>
  </article>
</Base>
